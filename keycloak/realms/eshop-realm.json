{
  "realm": "eshop",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "roles": {
    "realm": [
      { "name": "customer", "description": "Registered shopper" },
      { "name": "support-agent", "description": "Handles returns and customer orders" },
      { "name": "fulfillment-manager", "description": "Advances order status (process/ship/deliver)" },
      { "name": "catalog-manager", "description": "Manages products and coupons" },
      { "name": "super-admin", "description": "Full administration incl. user/role management" }
    ]
  },
  "clients": [
    {
      "clientId": "eshop-spa",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "attributes": { "pkce.code.challenge.method": "S256" },
      "protocolMappers": [
        {
          "name": "eshop-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "eshop-api",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "customer1",
      "enabled": true,
      "email": "customer1@eshop.local",
      "emailVerified": true,
      "firstName": "Cem",
      "lastName": "Customer",
      "credentials": [{ "type": "password", "value": "Passw0rd!", "temporary": false }],
      "realmRoles": ["customer"]
    },
    {
      "username": "admin1",
      "enabled": true,
      "email": "admin1@eshop.local",
      "emailVerified": true,
      "firstName": "Ada",
      "lastName": "Admin",
      "credentials": [{ "type": "password", "value": "Passw0rd!", "temporary": false }],
      "realmRoles": ["super-admin", "catalog-manager", "support-agent", "fulfillment-manager", "customer"]
    }
  ]
}
