# Copy this file to .env and adjust for your environment.
# docker-compose reads these values; .env is gitignored so real secrets stay out of the repo.

# PostgreSQL (Catalog + Basket)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# SQL Server (Order)
SQLSERVER_SA_PASSWORD=MyDb1234!

# RabbitMQ (message broker)
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
